# =============================================================================
# Frontend Environment Variables
# Copy this file: cp .env.example .env
# Then fill in your real values in .env
# =============================================================================

# ── Supabase (NEXT_PUBLIC_ prefix = accessible in browser) ────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ── Pinecone (server-side API routes only) ─────────────────────────────────────
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=ai-news-feeder

# ── Facebook / Meta (social posting) ──────────────────────────────────────────
FB_TOKEN=your_facebook_token_here
FB_PAGE_ID=your_facebook_page_id_here
IG_ACCOUNT_ID=your_instagram_account_id_here

# ── Twitter / X (via twitterapi.io) ────────────────────────────────────────────
TWITTER_API_KEY=
TWITTER_USERNAME=
TWITTER_EMAIL=
TWITTER_PASSWORD=
TWITTER_PROXY=
TWITTER_TOTP=
