# =============================================================================
# Backend Environment Variables
# Copy this file: cp .env.example .env
# Then fill in your real values in .env
# =============================================================================

# ── LiteLLM Proxy (Main Agent + Feeder Agent) ─────────────────────────────────
OPENAI_API_KEY=your_litellm_api_key_here
OPENAI_BASE_URL=http://your-litellm-server-ip:4000

# ── LangSmith (required for LangGraph server) ─────────────────────────────────
LANGSMITH_API_KEY=your_langsmith_api_key_here

# ── Tavily (web search) ────────────────────────────────────────────────────────
TAVILY_API_KEY=your_tavily_api_key_here

# ── Linkup (web search) ────────────────────────────────────────────────────────
LINKUP_API_KEY=your_linkup_api_key_here

# ── Brave Search (image search) ────────────────────────────────────────────────
BRAVE_API_KEY=your_brave_api_key_here

# ── Exa AI (fallback extract) ────────────────────────────────────────────────
EXA_API_KEY=your_exa_api_key_here

# ── Parallel AI (fallback search) ──────────────────────────────────────────
PARALLEL_API_KEY=your_parallel_ai_key_here

# ── Vercel AI Gateway (Gemini image editing) ───────────────────────────────────
AI_GATEWAY_API_KEY=your_vercel_ai_gateway_key_here

# ── Supabase ───────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ── Pinecone ───────────────────────────────────────────────────────────────────
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=ai-news-feeder

# ── Next.js app URL (for cron auto-publish) ────────────────────────────────
NEXT_APP_URL=http://localhost:3000

# ── Cerebras (Feeder Dedup Agent) ──────────────────────────────────────────────
CEREBRAS_API_KEY=your_cerebras_api_key_here

# ── KIE AI (Image editing — used by the Python agent) ─────────────────────────
KIE_API_KEY=your_kie_ai_api_key_here

# ── Next.js app URL (cron scheduler POSTs here to trigger auto-publish) ────────
# Set this to wherever your Next.js frontend is running.
# The Python cron_scheduler.py reads this as NEXT_APP_URL or NEXT_PUBLIC_APP_URL.
NEXT_APP_URL=http://localhost:3000

# NOTE: Social platform credentials (FB_TOKEN, FB_PAGE_ID, IG_ACCOUNT_ID,
# TWITTER_API_KEY, etc.) go in the FRONTEND env file:
#   deep-agents-ui-main/.env.local
# They are read by the Next.js /api/publish route, not by Python.

# ── WordPress Blog Publisher ────────────────────────────────────────────────────
# Your WordPress site URL (must be HTTPS in production)
WP_SITE_URL=https://yoursite.com

# WordPress admin username (the one you log in with)
WP_USERNAME=your_wp_admin_username

# WordPress Application Password — NOT your login password!
# Generate it: WP Admin → Users → Profile → Application Passwords → Add New
# It looks like: xxxx xxxx xxxx xxxx xxxx xxxx (spaces are fine, keep them)
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# Post status: "draft" (safe, review before going live) or "publish" (immediate)
# Start with "draft" until you are happy with the output quality.
WP_POST_STATUS=draft
